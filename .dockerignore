# Keep the build context small and let the Fly volume own runtime data.

# Deps are reinstalled inside the image
node_modules
**/node_modules

# Runtime data — lives on the persistent volume, never bake it into the image
data

# Build artifacts / design reference (not needed at runtime; the UI is public/)
web-dist
redesign/

# Secrets — set these with `fly secrets set` instead
.env
.env.*

# Git + OS cruft
.git
.gitignore
.DS_Store
*.log
err.txt

# Release archives and the stale nested copy
*.tar.gz
otg-app/

# Docs / scratch files
*.docx
*.pptx
*.xlsx
*.csv
COMMIT_*.txt

# Fly's own files
fly.toml
.fly
