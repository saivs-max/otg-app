# Keep the build context small and let the Fly volume own runtime data.

# Deps are reinstalled inside the image (root + the UI builder stage).
# Use ** so nested ones (redesign/react-app/node_modules) are excluded too.
**/node_modules

# Runtime data — lives on the persistent volume, never bake it into the image
data

# The UI is built INSIDE the image (multi-stage). Don't ship a local/stale copy;
# the builder stage produces a fresh web-dist and copies it into the runtime.
web-dist
redesign/react-app/dist

# Redesign extras not needed to BUILD the UI (the react-app source IS needed and
# is intentionally included so the builder stage can compile it).
redesign/CaperCostWise_Redesign_Prototype.html
redesign/adopt

# Secrets — set these with `fly secrets set` instead
.env
.env.*

# Git + OS cruft
.git
.gitignore
.DS_Store
*.log
err.txt

# Release archives and the stale nested copy (not needed at runtime)
*.tar.gz
otg-app/

# Docs / scratch files
*.docx
*.pptx
*.xlsx
*.csv
COMMIT_*.txt

# Fly's own files
fly.toml
.fly
