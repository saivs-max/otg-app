# Copy this file to `.env` and fill in your real values.
# `.env` is loaded automatically by `npm start` via Node's --env-file-if-exists flag.
# DO NOT commit `.env` to source control.

# ---- Freshdesk ----
# Subdomain (the part before .freshdesk.com in your URL)
#   e.g. for https://acme.freshdesk.com → acme
FRESHDESK_DOMAIN=

# API key from Freshdesk: profile picture (top right) → Profile Settings → API Key
FRESHDESK_API_KEY=

# ---- MaintainX ----
# API token from MaintainX: Settings → Integrations → API Tokens → Create
# Read-only permissions are sufficient.
MAINTAINX_API_KEY=
